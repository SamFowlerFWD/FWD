---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/blog/PostCard.astro';
import WhatsAppWidget from '../components/interactive/WhatsAppWidget.tsx';
import HeroSequence from '../components/homepage/HeroSequence.tsx';
import TestimonialCarousel from '../components/homepage/TestimonialCarousel.tsx';
import { getCollection } from 'astro:content';

const now = new Date();
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const services = [
  {
    icon: '&#9889;',
    name: 'Business Automation',
    price: 'From £799',
    description: 'Automate invoicing, emails, data entry and scheduling. Let technology handle the routine.',
    href: '/services/business-process-automation',
    cta: 'Learn more',
    accent: 'purple',
  },
  {
    icon: '&#127760;',
    name: 'Professional Websites',
    price: 'From £299',
    description: 'Fast, mobile-friendly websites built in 2 to 3 weeks. SEO-ready from day one.',
    href: '/services/professional-websites',
    cta: 'Learn more',
    accent: 'purple',
  },
  {
    icon: '&#128241;',
    name: 'Custom Apps',
    price: 'From £1,299',
    description: 'Booking systems, dashboards, internal tools. Built around your specific needs.',
    href: '/services/custom-app-development',
    cta: 'Learn more',
    accent: 'purple',
  },
  {
    icon: '&#128640;',
    name: 'Hosting & Maintenance',
    price: 'From £20/mo',
    description: 'Daily backups, security updates, performance monitoring and support when you need it.',
    href: '/services/hosting-maintenance',
    cta: 'Learn more',
    accent: 'purple',
  },
  {
    icon: '&#129302;',
    name: 'AI Training',
    price: 'From £299',
    description: 'Learn to use ChatGPT, Claude and AI tools properly. Hands-on training for your team.',
    href: '/services/ai-training',
    cta: 'Learn more',
    accent: 'purple',
  },
  {
    icon: '&#127918;',
    name: 'Playground',
    price: 'Interactive demos',
    description: 'See what I build in action. Booking systems, quote builders, data tools. Try them now.',
    href: '/playground',
    cta: 'Explore demos',
    accent: 'amber',
  },
];

const playgroundDemos = [
  { label: 'Quote Builder', gradient: 'from-purple-600 to-indigo-600', letter: 'Q' },
  { label: 'Booking System', gradient: 'from-blue-600 to-cyan-600', letter: 'B' },
  { label: 'ROI Calculator', gradient: 'from-amber-500 to-orange-600', letter: 'R' },
  { label: 'Review Writer', gradient: 'from-emerald-500 to-teal-600', letter: 'W' },
];
---

<Layout
  title="FWD Thinking Solutions | Web Developer for UK Businesses"
  description="Web development, automation, and custom apps for UK small businesses. One developer, no middlemen, transparent pricing. Based in Norwich, working UK-wide."
>
  <!-- Hero: Terminal → CTA → Build Sequence -->
  <HeroSequence client:load />

  <!-- ═══════════════════════════════════════════
       1. SERVICES SHOWCASE
       ═══════════════════════════════════════════ -->
  <section class="relative py-24 md:py-32 bg-gradient-to-b from-[#0f172a] via-[#1a1040] to-[#0f172a] overflow-hidden">
    <!-- Subtle background glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-purple-600/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16" data-animate>
        <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">What I Build</h2>
        <p class="text-xl text-gray-400">
          From simple websites to custom applications. Fixed quotes, no jargon, and I'll tell you if you don't need it.
        </p>
      </div>

      <!-- Stack on mobile, 3-col grid on desktop -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6" data-stagger>
        {services.map((service) => (
          <a
            href={service.href}
            class="group block"
            data-animate
          >
            <div class="h-full bg-white/5 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-white/10 transition-all duration-300 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1 hover:shadow-2xl hover:shadow-purple-900/20">
              <div class="text-3xl mb-4" set:html={service.icon} />
              <h3 class="text-lg font-bold text-white mb-1">{service.name}</h3>
              <p class={`text-sm font-medium mb-3 ${service.accent === 'amber' ? 'text-amber-400' : 'text-purple-400'}`}>{service.price}</p>
              <p class="text-gray-400 text-sm mb-5 leading-relaxed">{service.description}</p>
              <span class={`font-semibold text-sm inline-flex items-center gap-1 ${service.accent === 'amber' ? 'text-amber-400' : 'text-purple-400'}`}>
                {service.cta} <span class="arrow-slide">&rarr;</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       2. SOCIAL PROOF / TESTIMONIALS
       ═══════════════════════════════════════════ -->
  <section class="relative py-24 md:py-32 bg-gradient-to-b from-[#0f172a] via-[#12082a] to-[#0f172a]">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-500/20 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-500/20 to-transparent"></div>
    </div>

    <div class="relative max-w-5xl mx-auto px-6 md:px-8" data-animate>
      <h2 class="sr-only">Client Testimonials</h2>
      <TestimonialCarousel client:visible />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       3. TRY BEFORE YOU TALK
       ═══════════════════════════════════════════ -->
  <section class="relative py-24 md:py-32 bg-gradient-to-b from-[#0f172a] via-[#161830] to-[#0f172a]">
    <div class="max-w-5xl mx-auto px-6 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-14" data-animate>
        <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">Try Before You Talk</h2>
        <p class="text-xl text-gray-400">
          Interactive demos you can use right now. No signup needed.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-12" data-stagger>
        {playgroundDemos.map((demo) => (
          <a href="/playground" class="group block" data-animate>
            <div class="aspect-[4/3] rounded-xl bg-gradient-to-br overflow-hidden relative border border-white/10 transition-all duration-300 hover:border-white/20 hover:scale-[1.03]">
              <div class={`absolute inset-0 bg-gradient-to-br ${demo.gradient} opacity-80`}></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-4xl md:text-5xl font-bold text-white/20">{demo.letter}</span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/60 to-transparent">
                <span class="text-sm font-medium text-white">{demo.label}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center" data-animate>
        <a
          href="/playground"
          class="inline-flex items-center gap-3 px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-xl border border-white/20 hover:bg-white/15 hover:border-white/30 transition-all duration-300 hover:-translate-y-0.5 text-lg"
        >
          Open the Playground
          <svg class="w-5 h-5 arrow-slide" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       4. BLOG / LATEST THINKING
       ═══════════════════════════════════════════ -->
  {posts.length > 0 && (
    <section class="relative py-24 md:py-32 bg-gradient-to-b from-[#0f172a] via-[#1a1040] to-[#0f172a]">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-500/20 to-transparent"></div>
      </div>

      <div class="relative max-w-6xl mx-auto px-6 md:px-8">
        <div class="text-center max-w-3xl mx-auto mb-14" data-animate>
          <h2 class="text-4xl lg:text-5xl font-bold text-white mb-4">Latest Thinking</h2>
          <p class="text-xl text-gray-400">Practical guides and case studies. No filler.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-stagger>
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="group block" data-animate>
              <div class="h-full bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 overflow-hidden transition-all duration-300 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1">
                <!-- Thumbnail -->
                <div class="h-48 relative overflow-hidden">
                  {post.data.heroImage ? (
                    <img
                      src={post.data.heroImage}
                      alt={post.data.heroImageAlt || post.data.title}
                      class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                      width="400"
                      height="192"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-purple-600 to-blue-600 flex items-center justify-center">
                      <span class="text-white/20 text-6xl font-bold">{post.data.title.charAt(0)}</span>
                    </div>
                  )}
                </div>
                <!-- Content -->
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-3">
                    {post.data.category && (
                      <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-purple-500/20 text-purple-300">
                        {post.data.category === 'case-studies' ? 'Case Study' :
                         post.data.category === 'web-development' ? 'Web Development' :
                         post.data.category.charAt(0).toUpperCase() + post.data.category.slice(1)}
                      </span>
                    )}
                    <time datetime={post.data.pubDate.toISOString()} class="text-xs text-gray-500">
                      {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                    </time>
                  </div>
                  <h3 class="text-lg font-bold text-white mb-2 group-hover:text-purple-300 transition-colors">{post.data.title}</h3>
                  <p class="text-gray-400 text-sm line-clamp-2">{post.data.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-12" data-animate>
          <a href="/blog" class="inline-flex items-center gap-2 text-purple-400 font-semibold hover:text-purple-300 transition-colors text-lg group">
            View all posts
            <svg class="w-5 h-5 arrow-slide" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       5. FINAL CTA
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center justify-center bg-gradient-to-b from-[#0f172a] via-[#1e1040] to-[#0A0E27] overflow-hidden">
    <!-- Ambient glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-purple-600/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 left-1/4 w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative text-center max-w-4xl mx-auto px-6 md:px-8 py-24" data-animate>
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-8 leading-tight">
        Ready to build something?
      </h2>
      <p class="text-xl md:text-2xl text-gray-400 mb-12 max-w-2xl mx-auto">
        No sales pitch, no pressure. Just a quick chat about what you need and whether I can help.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://wa.me/447584417830?text=Hi%20Sam%2C%20I%20found%20your%20website%20and%20I%27m%20interested%20in%20discussing%20a%20project."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 bg-amber-500 text-slate-900 font-bold rounded-xl hover:bg-amber-400 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-amber-500/25 text-lg"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Chat on WhatsApp
        </a>
        <a
          href="/work"
          class="inline-flex items-center gap-3 px-8 py-4 bg-transparent text-white font-semibold rounded-xl border border-white/20 hover:bg-white/10 hover:border-white/30 transition-all duration-300 hover:-translate-y-0.5 text-lg"
        >
          See My Work
          <svg class="w-5 h-5 arrow-slide" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <WhatsAppWidget client:idle message="Hi Sam, I found your website and I'm interested in discussing a project." />
</Layout>
