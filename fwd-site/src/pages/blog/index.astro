---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/layout/Section.astro';
import SmartCTA from '../../components/interactive/SmartCTA.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.pubDate <= now))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog | Web Development & Automation Insights | FWD"
  description="Practical guides, case studies, and insights on web development, business automation, and custom software for UK small businesses."
>
  <!-- Hero -->
  <section class="relative py-20 bg-slate-900">
    <div class="container relative z-10 mx-auto px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center text-white">
        <h1 class="text-5xl lg:text-6xl font-bold mb-6">
          The FWD <span class="text-amber-400">Blog</span>
        </h1>
        <p class="text-xl text-gray-200">
          Practical guides, case studies, and insights from building software for UK businesses.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <Section variant="default">
    {posts.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-gray-500 text-lg">No posts yet. Check back soon.</p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto" data-stagger>
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage || post.data.image || ''}
            heroImageAlt={post.data.heroImageAlt || post.data.title}
            category={post.data.category}
            slug={post.id}
          />
        ))}
      </div>
    )}
  </Section>

  <!-- CTA -->
  <Section variant="muted">
    <SmartCTA
      heading="Got a Project in Mind?"
      text="I'd love to hear about it. Let's chat about what you need."
      primaryWhatsappMessage="Hi Sam, I was reading your blog and I'd like to discuss a project."
      secondaryLabel="See My Work"
      secondaryHref="/work"
    />
  </Section>

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "FWD Thinking Solutions Blog",
    "description": "Practical guides, case studies, and insights about web development and automation for UK businesses.",
    "url": "https://f-w-d.co.uk/blog",
    "publisher": {
      "@type": "Organization",
      "name": "FWD Thinking Solutions",
      "url": "https://f-w-d.co.uk"
    }
  })} />
</Layout>
