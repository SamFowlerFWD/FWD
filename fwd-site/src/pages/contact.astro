---
import Layout from '../layouts/Layout.astro';
import Section from '../components/layout/Section.astro';
import ContactForm from '../components/interactive/ContactForm.tsx';
---

<Layout
  title="Get in Touch | FWD Thinking Solutions"
  description="Contact FWD for web development, automation, or custom apps. Based in Norwich, working UK-wide. WhatsApp, email, or contact form."
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-slate-900">
    <div class="container relative z-10 mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center text-white">
        <h1 class="text-5xl lg:text-6xl font-bold mb-6">
          Get in <span class="text-amber-400">Touch</span>
        </h1>
        <p class="text-xl text-gray-100">
          No sales pitch, no pressure. Just tell me what you need and I'll let you know how I can help.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Options -->
  <Section variant="default">
    <div class="max-w-4xl mx-auto">
      <!-- Quick Contact Methods -->
      <div class="grid md:grid-cols-2 gap-6 mb-16">
        <a href="https://wa.me/447584417830?text=Hi%20Sam%2C%20I%27d%20like%20to%20chat%20about%20a%20project." target="_blank" rel="noopener noreferrer" class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100 card-hover group text-center" data-animate>
          <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-green-500 transition-colors">
            <svg class="w-8 h-8 text-green-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-900 mb-3">WhatsApp</h2>
          <p class="text-gray-600 mb-4">The quickest way to reach me. I typically reply within a few hours.</p>
          <span class="text-green-600 font-semibold inline-flex items-center gap-1">Message now <span class="arrow-slide">&rarr;</span></span>
        </a>

        <a href="mailto:sam@f-w-d.co.uk" class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100 card-hover group text-center" data-animate>
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-500 transition-colors">
            <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-900 mb-3">Email</h2>
          <p class="text-gray-600 mb-4">For detailed enquiries or if you prefer email. I'll get back to you within a day.</p>
          <span class="text-blue-600 font-semibold inline-flex items-center gap-1">sam@f-w-d.co.uk <span class="arrow-slide">&rarr;</span></span>
        </a>
      </div>

      <!-- Contact Form -->
      <div class="max-w-lg mx-auto" data-animate>
        <h2 class="text-2xl font-bold text-slate-900 mb-2 text-center">Or Send a Message</h2>
        <p class="text-gray-600 text-center mb-8">I typically reply within a few hours during business days.</p>
        <ContactForm client:visible />
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-500 text-sm">
          Based in Norwich, Norfolk. Working with businesses across the UK.
        </p>
      </div>
    </div>
  </Section>

  <!-- ContactPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact FWD Thinking Solutions",
    "url": "https://f-w-d.co.uk/contact",
    "mainEntity": {
      "@type": "Organization",
      "name": "FWD Thinking Solutions",
      "email": "sam@f-w-d.co.uk",
      "telephone": "+447584417830"
    }
  })} />
</Layout>
