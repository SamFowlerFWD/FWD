---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import SmartCTA from '../../components/interactive/SmartCTA.astro';
import FreshnessBadge from '../../components/content/FreshnessBadge.astro';

const faqs = [
  {
    question: "What's included in hosting?",
    answer: "Daily backups, security updates, performance monitoring, and email support. I keep your site running so you can focus on your business."
  },
  {
    question: "Can I host elsewhere?",
    answer: "Yes. I build sites that can be hosted anywhere. Managed hosting through me is an option, not a requirement."
  },
  {
    question: "What if my site goes down?",
    answer: "I monitor uptime and respond quickly to any issues. Most problems are resolved before you even notice them."
  },
  {
    question: "Do I need a maintenance plan?",
    answer: "Not necessarily, but websites need regular updates to stay secure and perform well. Without maintenance, security vulnerabilities can develop over time."
  }
];
---

<Layout
  title="Website Hosting & Maintenance | From £20/month | FWD"
  description="Reliable website hosting with daily backups, security updates, uptime monitoring, and UK-based support. Plans from £20 per month."
>
  <Breadcrumbs path="/services/hosting-maintenance" />

  <!-- Hero Section -->
  <section class="relative py-20 bg-slate-900">
    <div class="absolute inset-0 bg-ai-mesh opacity-20"></div>
    <div class="container relative z-10 mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center text-white">
        <h1 class="text-5xl lg:text-6xl font-bold mb-6">
          Hosting & <span class="text-amber-400">Maintenance</span>
        </h1>
        <p class="text-xl text-gray-100 mb-8">
          Reliable hosting with daily backups, security updates, and support when you need it. I keep your website running so you don't have to think about it.
        </p>
        <p class="text-lg text-amber-400 font-semibold mb-8">From £20/month</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/447584417830?text=Hi%20Sam%2C%20I'm%20interested%20in%20hosting%20for%20my%20website." target="_blank" rel="noopener noreferrer" class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-4 px-8 rounded-lg transition-colors shadow-lg inline-block">
            Get in Touch
          </a>
          <a href="#pricing" class="bg-white/10 backdrop-blur-sm border-2 border-white text-white font-bold py-4 px-8 rounded-lg hover:bg-white hover:text-slate-900 transition-all inline-block">
            View Plans
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-slate-900 mb-4">
            What's Included
          </h2>
          <p class="text-xl text-gray-600">
            Everything your website needs to stay healthy and secure.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {[
            {
              icon: "\u{1F4BE}",
              title: "Daily Backups",
              description: "Automatic daily backups stored securely, so your data is always safe."
            },
            {
              icon: "\u{1F512}",
              title: "Security Updates",
              description: "Regular security patches and updates to keep your site protected."
            },
            {
              icon: "\u{1F680}",
              title: "Performance",
              description: "Fast servers and optimisation to keep your site loading quickly."
            },
            {
              icon: "\u{1F4CA}",
              title: "Monitoring",
              description: "I keep an eye on your site and fix issues before they become problems."
            },
            {
              icon: "\u{1F6E1}\u{FE0F}",
              title: "SSL Certificate",
              description: "Free SSL certificate included for secure connections."
            },
            {
              icon: "\u{1F4E7}",
              title: "Support",
              description: "Email support when you need help or have questions about your site."
            }
          ].map(feature => (
            <div class="bg-gray-50 rounded-xl p-6">
              <div class="text-3xl mb-3">{feature.icon}</div>
              <h3 class="text-lg font-bold text-slate-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-slate-900 mb-4">
            How It Works
          </h2>
        </div>

        <div class="space-y-6">
          {[
            {
              step: "1",
              title: "We Set Things Up",
              description: "I migrate your existing site or set up hosting for your new build. No downtime during the switch."
            },
            {
              step: "2",
              title: "I Handle the Technical Side",
              description: "Backups, updates, security patches, and performance monitoring all happen automatically. You don't need to do a thing."
            },
            {
              step: "3",
              title: "You Focus on Your Business",
              description: "If something needs attention, I sort it out. If you have questions, I'm here to help. Simple as that."
            }
          ].map(item => (
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-amber-500 rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">
                {item.step}
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-1">{item.title}</h3>
                <p class="text-gray-600">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Who Is This For? -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-900 mb-6">Who Is This For?</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          Hosting and maintenance is for any business that wants their website looked after properly without worrying about the technical side. Whether I built your site or someone else did, I can take care of backups, updates, and security so you can focus on running your business.
        </p>
        <p class="text-gray-600 leading-relaxed">
          This is particularly popular with small business owners across Norwich, Norfolk and the UK who don't have an in-house IT team. Rather than paying hourly when something breaks, a monthly plan means your site is proactively maintained and issues are caught early.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Plans -->
  <section id="pricing" class="py-20 bg-gray-50">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-slate-900 mb-4">
            Hosting Plans
          </h2>
          <p class="text-xl text-gray-600">
            Simple monthly pricing. No contracts, cancel anytime.
          </p>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
          <!-- Standard -->
          <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8">
            <div class="text-center mb-6">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Standard</h3>
              <p class="text-gray-600 mb-4">For small websites</p>
              <div class="text-4xl font-bold text-slate-900 mb-2">£20</div>
              <p class="text-gray-500 text-sm">per month</p>
            </div>
            <ul class="space-y-3 mb-8">
              {[
                "Daily backups",
                "SSL certificate",
                "Security updates",
                "Performance monitoring",
                "Email support",
                "Monthly reports"
              ].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-success-green mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-gray-700">{item}</span>
                </li>
              ))}
            </ul>
            <a href="https://wa.me/447584417830?text=Hi%20Sam%2C%20I'm%20interested%20in%20hosting%20for%20my%20website." target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-slate-900 text-white font-semibold py-3 rounded-lg hover:bg-slate-800 transition-colors">
              Get Started
            </a>
          </div>

          <!-- Premium -->
          <div class="bg-white rounded-2xl shadow-xl border-2 border-amber-500 p-8 relative">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-amber-500 text-white text-sm font-semibold px-4 py-1 rounded-full">
              MOST POPULAR
            </div>
            <div class="text-center mb-6">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Premium</h3>
              <p class="text-gray-600 mb-4">For business websites</p>
              <div class="text-4xl font-bold text-slate-900 mb-2">£149</div>
              <p class="text-gray-500 text-sm">per month</p>
            </div>
            <ul class="space-y-3 mb-8">
              {[
                "Everything in Standard",
                "Priority support",
                "Performance optimisation",
                "Content updates (2/month)",
                "Uptime monitoring",
                "Weekly reports"
              ].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-success-green mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-gray-700">{item}</span>
                </li>
              ))}
            </ul>
            <a href="https://wa.me/447584417830?text=Hi%20Sam%2C%20I'm%20interested%20in%20hosting%20for%20my%20website." target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-amber-500 text-white font-semibold py-3 rounded-lg hover:bg-amber-600 transition-colors">
              Get Started
            </a>
          </div>

          <!-- Enterprise -->
          <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8">
            <div class="text-center mb-6">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Enterprise</h3>
              <p class="text-gray-600 mb-4">For high-traffic sites</p>
              <div class="text-4xl font-bold text-slate-900 mb-2">Custom</div>
              <p class="text-gray-500 text-sm">tailored to your needs</p>
            </div>
            <ul class="space-y-3 mb-8">
              {[
                "Everything in Premium",
                "Dedicated resources",
                "Advanced security",
                "Unlimited content updates",
                "Phone support",
                "Custom SLA"
              ].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-success-green mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-gray-700">{item}</span>
                </li>
              ))}
            </ul>
            <a href="https://wa.me/447584417830?text=Hi%20Sam%2C%20I'm%20interested%20in%20hosting%20for%20my%20website." target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-slate-900 text-white font-semibold py-3 rounded-lg hover:bg-slate-800 transition-colors">
              Get in Touch
            </a>
          </div>
        </div>

        <div class="mt-8 text-center">
          <p class="text-gray-600 text-sm">
            Already hosted elsewhere? I offer free migration to move your site over with no downtime.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Related Services</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          <a href="/services/professional-websites" class="bg-gray-50 rounded-lg p-4 hover:bg-gray-100 transition-colors group">
            <h3 class="font-semibold text-slate-900 group-hover:text-ai-purple transition-colors">Professional Websites</h3>
            <p class="text-sm text-gray-600 mt-1">Need a new website to host?</p>
          </a>
          <a href="/services/business-process-automation" class="bg-gray-50 rounded-lg p-4 hover:bg-gray-100 transition-colors group">
            <h3 class="font-semibold text-slate-900 group-hover:text-ai-purple transition-colors">Business Automation</h3>
            <p class="text-sm text-gray-600 mt-1">Automate your business processes</p>
          </a>
          <a href="/services/custom-app-development" class="bg-gray-50 rounded-lg p-4 hover:bg-gray-100 transition-colors group">
            <h3 class="font-semibold text-slate-900 group-hover:text-ai-purple transition-colors">Custom App Development</h3>
            <p class="text-sm text-gray-600 mt-1">Build a custom application</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-slate-900 mb-4">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-4">
          {faqs.map(item => (
            <details class="bg-white rounded-lg border border-gray-100 group shadow-sm">
              <summary class="p-6 cursor-pointer list-none flex items-center justify-between hover:bg-gray-50 rounded-lg">
                <span class="font-semibold text-slate-900 pr-4">{item.question}</span>
                <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-6 pb-6">
                <p class="text-gray-600">{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SmartCTA -->
  <section class="py-20 bg-slate-900 text-white">
    <div class="container mx-auto px-6 lg:px-8">
      <SmartCTA
        heading="Stop Worrying About Your Website"
        text="Let me handle the hosting and maintenance while you focus on running your business."
        primaryWhatsappMessage="Hi Sam, I'm interested in hosting for my website."
        secondaryLabel="View My Work"
        secondaryHref="/work"
      />
      <div class="text-center mt-6">
        <FreshnessBadge />
      </div>
    </div>
  </section>

  <!-- FAQPage Schema -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    })}
  </script>

  <!-- Service Schema -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Website Hosting & Maintenance",
      "description": "Reliable website hosting with daily backups, security updates, and support for UK businesses. From £20/month.",
      "provider": {
        "@type": "Organization",
        "name": "FWD Thinking Solutions",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Norwich",
          "addressRegion": "Norfolk",
          "addressCountry": "GB"
        }
      },
      "areaServed": {
        "@type": "Place",
        "name": "United Kingdom"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Hosting Plans",
        "itemListElement": [
          {
            "@type": "Offer",
            "name": "Standard Hosting",
            "price": "99",
            "priceCurrency": "GBP",
            "description": "Daily backups, security updates, and email support"
          },
          {
            "@type": "Offer",
            "name": "Premium Hosting",
            "price": "149",
            "priceCurrency": "GBP",
            "description": "Priority support, performance optimisation, and content updates"
          }
        ]
      }
    })}
  </script>
</Layout>
