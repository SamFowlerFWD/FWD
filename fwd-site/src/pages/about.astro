---
import Layout from '../layouts/Layout.astro';
import Section from '../components/layout/Section.astro';
import SmartCTA from '../components/interactive/SmartCTA.astro';
import ProcessSteps from '../components/content/ProcessSteps.astro';
import { generatePersonSchema } from '../lib/schema';
---

<Layout
  title="About Sam Fowler | FWD Thinking Solutions"
  description="Meet Sam Fowler, the developer behind FWD. Dozens of projects across diverse sectors. Based in Norwich, working with businesses across the UK."
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-slate-900">
    <div class="container relative z-10 mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center text-white">
        <h1 class="text-5xl lg:text-6xl font-bold mb-6">
          About <span class="text-amber-400">FWD</span>
        </h1>
        <p class="text-xl text-gray-100 mb-8">
          Practical technology solutions for businesses that want to work smarter.
        </p>
      </div>
    </div>
  </section>

  <!-- Who I Am -->
  <Section variant="default">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-6" data-animate>Who I Am</h2>
      <p class="text-gray-600 leading-relaxed mb-4" data-animate>
        I'm Sam Fowler, a software developer based in Norwich, Norfolk. I run FWD Thinking Solutions, helping businesses work smarter with technology. Whether that's building a <a href="/services/professional-websites" class="text-[var(--colour-primary)] hover:underline">website</a>, <a href="/services/business-process-automation" class="text-[var(--colour-primary)] hover:underline">automating repetitive tasks</a>, creating a <a href="/services/custom-app-development" class="text-[var(--colour-primary)] hover:underline">custom booking system</a>, or developing a mobile app, I work directly with business owners to understand what they need and deliver something that genuinely helps.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4" data-animate>
        I got into development because I like building things that solve real problems. Not impressive-looking demos, not overengineered solutions, but practical tools that save people time and money. That's still what drives every project I take on.
      </p>
      <p class="text-gray-600 leading-relaxed" data-animate>
        I'm also co-founder of <a href="/work/building-ask-stephen" class="text-[var(--colour-primary)] hover:underline">Ask Stephen</a>, a coaching platform I built from the ground up with a confidence coach. That project taught me what it means to be personally invested in the outcome, not just delivering a brief but building something you want to see succeed. I bring that same mindset to every client project.
      </p>
    </div>
  </Section>

  <!-- Why FWD Exists -->
  <Section variant="muted">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-6" data-animate>Why FWD Exists</h2>
      <p class="text-gray-600 leading-relaxed mb-4" data-animate>
        I started FWD because too many small businesses were paying over the odds for basic technology, or going without it entirely because agencies were too expensive or too complicated to deal with. Especially rural businesses and trades. They deserve better than a choice between a £10k agency quote and a DIY Wix site.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4" data-animate>
        My approach is straightforward: understand the problem, build the solution, support it afterwards. No middlemen, no jargon, no overselling. I give honest advice about what you need (and what you don't), provide <a href="/pricing" class="text-[var(--colour-primary)] hover:underline">fixed pricing</a> so there are no surprises, and I'm always available when you need help.
      </p>
      <p class="text-gray-600 leading-relaxed" data-animate>
        I also know where AI tools help and where proper code is better. I offer <a href="/services/ai-training" class="text-[var(--colour-primary)] hover:underline">AI training</a> for businesses that want to use ChatGPT and Claude effectively, and I build proper <a href="/services/business-process-automation" class="text-[var(--colour-primary)] hover:underline">automation</a> where a chat window isn't enough. Either way, you get honest advice about which approach fits.
      </p>
    </div>
  </Section>

  <!-- How I Work -->
  <Section variant="default">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-8 text-center" data-animate>How I Work</h2>
      <div class="grid md:grid-cols-2 gap-6" data-stagger>
        {[
          {
            title: "Direct Communication",
            description: "You deal with me directly. The person who actually builds your project. No account managers, no middlemen, no game of telephone."
          },
          {
            title: "End-to-End",
            description: "I handle everything from design and development to hosting and ongoing support. One point of contact for everything your project needs."
          },
          {
            title: "Honest Advice",
            description: "I'll tell you what you need and what you don't. If a simpler solution works better, that's what I'll recommend. Even if it means a smaller invoice."
          },
          {
            title: "Fixed Pricing",
            description: "Where possible, I provide fixed quotes so you know exactly what you're paying before we start. No hourly surprises, no scope creep invoices."
          }
        ].map(item => (
          <div class="bg-gray-50 rounded-xl p-6" data-animate>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Track Record -->
  <Section variant="dark">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-8 text-white" data-animate>Track Record</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6" data-stagger>
        {[
          { value: "Dozens of", label: "Projects Delivered" },
          { value: "Diverse", label: "Sectors Served" },
          { value: "5.0", label: "Client Rating" },
          { value: "UK-wide", label: "Clients Served" }
        ].map(stat => (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20" data-animate>
            <div class="text-3xl font-bold text-amber-400 mb-1">{stat.value}</div>
            <div class="text-sm text-gray-300">{stat.label}</div>
          </div>
        ))}
      </div>
      <p class="text-gray-300 mt-8 text-sm" data-animate>
        Clients across equestrian, manufacturing, pet services, sports, technology, retail, professional services, and construction.
      </p>
    </div>
  </Section>

  <!-- CTA -->
  <Section variant="default">
    <SmartCTA
      heading="Let's Work Together"
      text="Whether you need a website, an app, or automation, I'd be happy to chat about how I can help."
      primaryWhatsappMessage="Hi Sam, I found your website and I'm interested in discussing a project."
      secondaryLabel="View My Work"
      secondaryHref="/work"
    />
  </Section>

  <!-- Person Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(generatePersonSchema())} />
</Layout>
