---
export interface Props {
  stats: Array<{
    value: string;
    label: string;
  }>;
}

const { stats } = Astro.props;
---
<div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center py-8" data-stagger>
  {stats.map((stat) => (
    <div data-animate>
      <div class="text-3xl md:text-4xl font-bold text-[var(--colour-primary)] mb-1">{stat.value}</div>
      <div class="text-sm text-slate-500">{stat.label}</div>
    </div>
  ))}
</div>
