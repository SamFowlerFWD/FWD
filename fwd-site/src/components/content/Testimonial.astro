---
export interface Props {
  quote: string;
  name: string;
  role?: string;
  stars?: number;
  verified?: boolean;
}

const { quote, name, role, stars = 5, verified = true } = Astro.props;
---
<blockquote class="bg-white rounded-xl p-6 shadow-md border border-slate-100" data-animate>
  <div class="flex gap-0.5 mb-3" aria-label={`${stars} out of 5 stars`}>
    {Array.from({ length: stars }).map(() => (
      <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>
  <p class="text-slate-700 mb-4 italic">"{quote}"</p>
  <footer class="flex items-center justify-between">
    <cite class="not-italic">
      <span class="font-semibold text-slate-900">{name}</span>
      {role && <span class="block text-sm text-slate-500">{role}</span>}
    </cite>
    {verified && (
      <span class="inline-flex items-center gap-1 text-xs text-green-700 bg-green-50 px-2 py-1 rounded-full">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        Verified Google Review
      </span>
    )}
  </footer>
</blockquote>
